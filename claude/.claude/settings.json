{
  "cleanupPeriodDays": 99999,
  "env": {
    "ANTHROPIC_MODEL": "claude-opus-4-6[1m]"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "memsearch@memsearch-plugins": true,
    "code-simplifier@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "everything-evenhub@everything-evenhub": true,
    "clangd-lsp@claude-plugins-official": true,
    "artifact-hub@artifact-hub": true
  },
  "extraKnownMarketplaces": {
    "memsearch-plugins": {
      "source": {
        "source": "github",
        "repo": "zilliztech/memsearch"
      }
    },
    "everything-evenhub": {
      "source": {
        "source": "github",
        "repo": "even-realities/everything-evenhub"
      }
    },
    "artifact-hub": {
      "source": {
        "source": "github",
        "repo": "ijiwarunahello/artifact-hub"
      },
      "autoUpdate": true
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/ghq-root-guard.sh"
          }
        ]
      }
    ]
  },
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "skipAutoPermissionPrompt": true
}
